ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES = YES
CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER = NO
FRAMEWORK_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJAnimationKit" "${PODS_CONFIGURATION_BUILD_DIR}/CJAnimationKit-Swift" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "${PODS_CONFIGURATION_BUILD_DIR}/HWWeakTimer" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "${PODS_CONFIGURATION_BUILD_DIR}/Shimmer" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Animation" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Animation-Swift"
GCC_PREPROCESSOR_DEFINITIONS = $(inherited) COCOAPODS=1
HEADER_SEARCH_PATHS = $(inherited) "${PODS_CONFIGURATION_BUILD_DIR}/CJAnimationKit-Swift/CJAnimationKit_Swift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJAnimationKit/CJAnimationKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit/CJBaseUIKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit/CQDemoKit.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource/CQDemoResource.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/HWWeakTimer/HWWeakTimer.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Masonry/Masonry.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/Shimmer/Shimmer.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Animation-Swift/TSDemo_Animation_Swift.framework/Headers" "${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Animation/TSDemo_Animation.framework/Headers"
LD_RUNPATH_SEARCH_PATHS = $(inherited) /usr/lib/swift '@executable_path/Frameworks' '@loader_path/Frameworks'
LIBRARY_SEARCH_PATHS = $(inherited) "${TOOLCHAIN_DIR}/usr/lib/swift/${PLATFORM_NAME}" /usr/lib/swift
OTHER_LDFLAGS = $(inherited) -framework "CJAnimationKit" -framework "CJAnimationKit_Swift" -framework "CJBaseUIKit" -framework "CQDemoKit" -framework "CQDemoResource" -framework "Foundation" -framework "HWWeakTimer" -framework "Masonry" -framework "QuartzCore" -framework "Shimmer" -framework "SwiftUI" -framework "TSDemo_Animation" -framework "TSDemo_Animation_Swift" -framework "UIKit"
OTHER_MODULE_VERIFIER_FLAGS = $(inherited) "-F${PODS_CONFIGURATION_BUILD_DIR}/CJAnimationKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJAnimationKit-Swift" "-F${PODS_CONFIGURATION_BUILD_DIR}/CJBaseUIKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoKit" "-F${PODS_CONFIGURATION_BUILD_DIR}/CQDemoResource" "-F${PODS_CONFIGURATION_BUILD_DIR}/HWWeakTimer" "-F${PODS_CONFIGURATION_BUILD_DIR}/Masonry" "-F${PODS_CONFIGURATION_BUILD_DIR}/Shimmer" "-F${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Animation" "-F${PODS_CONFIGURATION_BUILD_DIR}/TSDemo_Animation-Swift"
OTHER_SWIFT_FLAGS = $(inherited) -D COCOAPODS
PODS_BUILD_DIR = ${BUILD_DIR}
PODS_CONFIGURATION_BUILD_DIR = ${PODS_BUILD_DIR}/$(CONFIGURATION)$(EFFECTIVE_PLATFORM_NAME)
PODS_PODFILE_DIR_PATH = ${SRCROOT}/.
PODS_ROOT = ${SRCROOT}/Pods
PODS_XCFRAMEWORKS_BUILD_DIR = $(PODS_CONFIGURATION_BUILD_DIR)/XCFrameworkIntermediates
USE_RECURSIVE_SCRIPT_INPUTS_IN_SCRIPT_PHASES = YES
